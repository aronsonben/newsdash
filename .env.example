# Vite environment variables must be prefixed with VITE_
VITE_API_BASE_URL=
VITE_API_KEY=
VITE_SITE_URL='http://localhost:5173'
VITE_SITE_TITLE='NewsDash (Dev)'

# ── Gemini API ─────────────────────────────────────────────────────────────────
# LOCAL DEV ONLY (npm run dev) — never set this in Vercel; it would be exposed in the browser bundle
VITE_GEMINI_API_KEY=

# PRODUCTION (Vercel serverless function) — set this in the Vercel dashboard, not here
# Server-side only; never prefixed with VITE_
GEMINI_API_KEY=

# Firebase client API key — used by the serverless cache functions (cache-read, cache-write)
# Set in .env.local for local dev (vercel dev), and in Vercel dashboard for production
FIREBASE_API_KEY=
